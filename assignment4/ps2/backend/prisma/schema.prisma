generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Student {
  id           Int      @id @default(autoincrement())
  full_name    String
  email        String   @unique
  password_hash String
  created_at   DateTime @default(now())

  @@map("students")
}
